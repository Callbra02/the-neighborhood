# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
/Unity Project/.utmp/
/Unity Project/[Ll]ibrary/
/Unity Project/[Tt]emp/
/Unity Project/[Oo]bj/
/Unity Project/[Bb]uild/
/Unity Project/[Bb]uilds/
/Unity Project/[Ll]ogs/
/Unity Project/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
/Unity Project/*.blend1
/Unity Project/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/Unity Project/[Mm]emoryCaptures/

# Recordings can get excessive in size
/Unity Project/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /Unity Project/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/Unity Project/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
/Unity Project/*.DotSettings.user

# Visual Studio cache directory
/Unity Project/.vs/

# Gradle cache directory
/Unity Project/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/Unity Project/ExportedObj/
/Unity Project/.consulo/
/Unity Project/*.csproj
/Unity Project/*.unityproj
/Unity Project/*.sln
/Unity Project/*.slnx
/Unity Project/*.suo
/Unity Project/*.tmp
/Unity Project/*.user
/Unity Project/*.userprefs
/Unity Project/*.pidb
/Unity Project/*.booproj
/Unity Project/*.svd
/Unity Project/*.pdb
/Unity Project/*.mdb
/Unity Project/*.opendb
/Unity Project/*.VC.db

# Unity3D generated meta files
/Unity Project/*.pidb.meta
/Unity Project/*.pdb.meta
/Unity Project/*.mdb.meta

# Unity3D generated file on crash reports
/Unity Project/sysinfo.txt

# Mono auto generated files
/Unity Project/mono_crash.*

# Builds
/Builds/*.apk
/Builds/*.aab
/Builds/*.unitypackage
/Builds/*.unitypackage.meta
/Builds/*.app

# Crashlytics generated file
/Unity Project/crashlytics-build.properties

# TestRunner generated files
/Unity Project/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/Unity Project/ServerData
/Unity Project/[Aa]ssets/StreamingAssets/aa*
/Unity Project/[Aa]ssets/AddressableAssetsData/link.xml*
/Unity Project/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/Unity Project/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/Unity Project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/Unity Project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/Unity Project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/Unity Project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/Unity Project/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Auto-generated cache in Assets folder
/Unity Project/[Aa]ssets/[Ss]ceneDependencyCache*
